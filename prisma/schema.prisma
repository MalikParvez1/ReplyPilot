generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // Hier stellen wir von sqlite auf postgresql um
}

// -----------------------------------------------------------------------------
// USER MODEL (Wird über den Clerk Webhook synchronisiert)
// -----------------------------------------------------------------------------
model User {
  id               String    @id @default(cuid())
  clerkId          String    @unique // Die ID, die von Clerk kommt
  email            String    @unique
  firstName        String?
  lastName         String?
  
  // Stripe & Abo-Daten
  stripeCustomerId String?   @unique
  stripePriceId    String?
  subscriptionEnd  DateTime?
  plan             String    @default("free") // "free", "starter", "pro", "business"

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relationen
  reviews          Review[]
  settings         Settings?
}

// -----------------------------------------------------------------------------
// SETTINGS MODEL (Für die "Markenstimme" und KI-Einstellungen)
// -----------------------------------------------------------------------------
model Settings {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  toneOfVoice    String   @default("professionell und freundlich") // Deine Markenstimme
  autoReply      Boolean  @default(false)
  language       String   @default("de")

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// REVIEW MODEL (Die Google-Bewertungen)
// -----------------------------------------------------------------------------
model Review {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  authorName     String
  rating         Int      // 1 bis 5 Sterne
  text           String?  @db.Text
  
  // Die von der KI generierte Antwort
  aiResponse     String?  @db.Text
  isPublished    Boolean  @default(false)
  
  // Optional: Die echte Google-Review-ID, falls du sie später synchronisierst
  googleReviewId String?  @unique

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}