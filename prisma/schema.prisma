// Dies ist dein Prisma Schema File
// Lerne mehr darüber hier: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // Passe dies an, falls du SQLite oder MySQL nutzt
}

model User {
  id               String     @id @default(cuid())
  clerkId          String     @unique
  email            String     @unique
  firstName        String?
  lastName         String?
  
  // Stripe & Tarif Info
  stripeCustomerId String?
  stripePriceId    String?
  subscriptionEnd  DateTime?
  plan             String     @default("starter") // "free", "starter", "pro", "business"
  
  // Neue 1-zu-n Beziehung: Ein Nutzer kann mehrere Standorte haben
  locations        Location[] 

  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

// NEU: Das Location-Modell
model Location {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name             String    // z.B. "Café Te - Mitte"
  googleBusinessId String?   // Die ID von Google für diesen Standort (falls später angebunden)
  
  // Jeder Standort bekommt SEINE EIGENEN Settings und Reviews
  settings         Settings?
  reviews          Review[]
  
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// Settings ist jetzt mit der Location verknüpft (nicht mehr direkt mit dem User)
model Settings {
  id                String   @id @default(cuid())
  
  locationId        String   @unique
  location          Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  
  businessName      String?
  businessType      String?
  toneOfVoice       String?
  additionalContext String?
  closingWord       String?
  forbiddenWords    String?
  
  autoReply         Boolean  @default(false)
  language          String   @default("de")
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Review ist jetzt mit der Location verknüpft
model Review {
  id                String   @id @default(cuid())
  
  locationId        String   
  location          Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  
  // Google Review Spezifika
  googleReviewId    String?  @unique
  authorName        String
  rating            Int
  comment           String
  
  // App Logik
  status            String   @default("UNANSWERED") // "UNANSWERED", "ANSWERED"
  replyText         String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}